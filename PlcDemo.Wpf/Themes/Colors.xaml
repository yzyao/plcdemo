<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Color x:Key="AppBackgroundColor">#FFF4F0E8</Color>
    <Color x:Key="SurfaceColor">#FFFDFBF7</Color>
    <Color x:Key="SurfaceAltColor">#FFF3ECE1</Color>
    <Color x:Key="AccentColor">#FF0F766E</Color>
    <Color x:Key="AccentHoverColor">#FF115E59</Color>
    <Color x:Key="AccentSoftColor">#FFB8E3DD</Color>
    <Color x:Key="TextColor">#FF1F2933</Color>
    <Color x:Key="TextMutedColor">#FF64748B</Color>
    <Color x:Key="BorderColor">#FFD8CDBF</Color>
    <Color x:Key="ShadowColor">#1A111827</Color>
    <Color x:Key="DangerColor">#FFB45309</Color>
    <Color x:Key="ReadHighlightColor">#FFE7F3FF</Color>
    <Color x:Key="ChangedHighlightColor">#FFFFF0C2</Color>
    <Color x:Key="WrittenHighlightColor">#FFD9F5E5</Color>
    <Color x:Key="InfoHighlightColor">#FFDCEBF9</Color>
    <Color x:Key="WarningHighlightColor">#FFFBE8C4</Color>
    <Color x:Key="CriticalHighlightColor">#FFF7D5D6</Color>
    <Color x:Key="IdleHighlightColor">#FFE8EDF3</Color>
    <Color x:Key="RunningHighlightColor">#FFD9F5E5</Color>
    <Color x:Key="NormalHighlightColor">#FFE2F2EA</Color>
    <Color x:Key="TrendLineColor">#FF0F766E</Color>
    <Color x:Key="TrendGridColor">#66D8CDBF</Color>

    <SolidColorBrush x:Key="AppBackgroundBrush" Color="{StaticResource AppBackgroundColor}" />
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceColor}" />
    <SolidColorBrush x:Key="SurfaceAltBrush" Color="{StaticResource SurfaceAltColor}" />
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}" />
    <SolidColorBrush x:Key="AccentHoverBrush" Color="{StaticResource AccentHoverColor}" />
    <SolidColorBrush x:Key="AccentSoftBrush" Color="{StaticResource AccentSoftColor}" />
    <SolidColorBrush x:Key="TextBrush" Color="{StaticResource TextColor}" />
    <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource TextMutedColor}" />
    <SolidColorBrush x:Key="BorderBrushSoft" Color="{StaticResource BorderColor}" />
    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource DangerColor}" />
    <SolidColorBrush x:Key="ReadHighlightBrush" Color="{StaticResource ReadHighlightColor}" />
    <SolidColorBrush x:Key="ChangedHighlightBrush" Color="{StaticResource ChangedHighlightColor}" />
    <SolidColorBrush x:Key="WrittenHighlightBrush" Color="{StaticResource WrittenHighlightColor}" />
    <SolidColorBrush x:Key="InfoHighlightBrush" Color="{StaticResource InfoHighlightColor}" />
    <SolidColorBrush x:Key="WarningHighlightBrush" Color="{StaticResource WarningHighlightColor}" />
    <SolidColorBrush x:Key="CriticalHighlightBrush" Color="{StaticResource CriticalHighlightColor}" />
    <SolidColorBrush x:Key="IdleHighlightBrush" Color="{StaticResource IdleHighlightColor}" />
    <SolidColorBrush x:Key="RunningHighlightBrush" Color="{StaticResource RunningHighlightColor}" />
    <SolidColorBrush x:Key="NormalHighlightBrush" Color="{StaticResource NormalHighlightColor}" />
    <SolidColorBrush x:Key="TrendLineBrush" Color="{StaticResource TrendLineColor}" />
    <SolidColorBrush x:Key="TrendGridBrush" Color="{StaticResource TrendGridColor}" />
</ResourceDictionary>
