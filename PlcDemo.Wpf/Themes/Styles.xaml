<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:models="clr-namespace:PlcDemo.Wpf.Models">
    <DropShadowEffect x:Key="CardShadow" BlurRadius="22" ShadowDepth="8" Color="{StaticResource ShadowColor}" Opacity="0.16" />

    <Style x:Key="HeroCard" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
        <Setter Property="CornerRadius" Value="26" />
        <Setter Property="Padding" Value="28" />
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushSoft}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Effect" Value="{DynamicResource CardShadow}" />
    </Style>

    <Style x:Key="Card" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
        <Setter Property="CornerRadius" Value="22" />
        <Setter Property="Padding" Value="22" />
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushSoft}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Effect" Value="{DynamicResource CardShadow}" />
    </Style>

    <Style x:Key="HeroTitle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="34" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
    </Style>

    <Style x:Key="HeroSubtitle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style x:Key="SectionTitle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="18" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
    </Style>

    <Style TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Segoe UI" />
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
    </Style>

    <Style TargetType="TextBox">
        <Setter Property="Margin" Value="0" />
        <Setter Property="Padding" Value="10,8" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushSoft}" />
        <Setter Property="Background" Value="White" />
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
    </Style>

    <Style TargetType="ComboBox">
        <Setter Property="Margin" Value="0" />
        <Setter Property="Padding" Value="8,6" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushSoft}" />
        <Setter Property="Background" Value="White" />
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
    </Style>

    <Style TargetType="Button">
        <Setter Property="Padding" Value="16,10" />
        <Setter Property="Margin" Value="0" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
        <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushSoft}" />
    </Style>

    <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
        <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
        <Setter Property="Foreground" Value="White" />
    </Style>

    <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
        <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushSoft}" />
    </Style>

    <Style TargetType="ListBox">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
    </Style>

    <Style TargetType="ListBoxItem">
        <Setter Property="Padding" Value="10,6" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
    </Style>

    <Style x:Key="RegisterRowStyle" TargetType="DataGridRow">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Style.Triggers>
            <DataTrigger Binding="{Binding State}" Value="{x:Static models:RegisterValueState.Read}">
                <Setter Property="Background" Value="{DynamicResource ReadHighlightBrush}" />
            </DataTrigger>
            <DataTrigger Binding="{Binding State}" Value="{x:Static models:RegisterValueState.Changed}">
                <Setter Property="Background" Value="{DynamicResource ChangedHighlightBrush}" />
            </DataTrigger>
            <DataTrigger Binding="{Binding State}" Value="{x:Static models:RegisterValueState.Written}">
                <Setter Property="Background" Value="{DynamicResource WrittenHighlightBrush}" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="AlarmInfoRowStyle" TargetType="DataGridRow">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Style.Triggers>
            <DataTrigger Binding="{Binding Severity}" Value="{x:Static models:AlarmSeverity.Info}">
                <Setter Property="Background" Value="{DynamicResource InfoHighlightBrush}" />
            </DataTrigger>
            <DataTrigger Binding="{Binding Severity}" Value="{x:Static models:AlarmSeverity.Warning}">
                <Setter Property="Background" Value="{DynamicResource WarningHighlightBrush}" />
            </DataTrigger>
            <DataTrigger Binding="{Binding Severity}" Value="{x:Static models:AlarmSeverity.Critical}">
                <Setter Property="Background" Value="{DynamicResource CriticalHighlightBrush}" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="CaseStatusCardStyle" TargetType="Border">
        <Setter Property="Margin" Value="0,0,12,12" />
        <Setter Property="Padding" Value="16" />
        <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushSoft}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="18" />
        <Style.Triggers>
            <DataTrigger Binding="{Binding Level}" Value="{x:Static models:CaseStatusLevel.Idle}">
                <Setter Property="Background" Value="{DynamicResource IdleHighlightBrush}" />
            </DataTrigger>
            <DataTrigger Binding="{Binding Level}" Value="{x:Static models:CaseStatusLevel.Running}">
                <Setter Property="Background" Value="{DynamicResource RunningHighlightBrush}" />
            </DataTrigger>
            <DataTrigger Binding="{Binding Level}" Value="{x:Static models:CaseStatusLevel.Normal}">
                <Setter Property="Background" Value="{DynamicResource NormalHighlightBrush}" />
            </DataTrigger>
            <DataTrigger Binding="{Binding Level}" Value="{x:Static models:CaseStatusLevel.Warning}">
                <Setter Property="Background" Value="{DynamicResource WarningHighlightBrush}" />
            </DataTrigger>
            <DataTrigger Binding="{Binding Level}" Value="{x:Static models:CaseStatusLevel.Critical}">
                <Setter Property="Background" Value="{DynamicResource CriticalHighlightBrush}" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="InterlockRowStyle" TargetType="DataGridRow">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Style.Triggers>
            <DataTrigger Binding="{Binding IsOk}" Value="True">
                <Setter Property="Background" Value="{DynamicResource NormalHighlightBrush}" />
            </DataTrigger>
            <DataTrigger Binding="{Binding IsOk}" Value="False">
                <Setter Property="Background" Value="{DynamicResource CriticalHighlightBrush}" />
            </DataTrigger>
        </Style.Triggers>
    </Style>
</ResourceDictionary>
